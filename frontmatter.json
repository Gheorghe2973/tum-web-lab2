{
  "$schema": "https://frontmatter.codes/schema/config.json",
  "frontMatter.framework.id": "jekyll",
  "frontMatter.preview.host": "http://localhost:4000",
  "frontMatter.content.publicFolder": "assets",
  "frontMatter.content.pageFolders": [
    {
      "title": "Products",
      "path": "[[workspace]]/_products",
      "contentTypes": ["product"]
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "product",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "required": true
        },
        {
          "name": "image",
          "type": "image",
          "required": false
        },
        {
          "name": "order",
          "type": "number",
          "required": false
        }
      ]
    }
  ]
}
